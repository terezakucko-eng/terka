# Server Configuration
PORT=3000

# SMTP Email Configuration
# Pro Gmail použijte app-specific password: https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Admin Email (kam budou chodit notifikace o rezervacích)
ADMIN_EMAIL=info@movein.cz

# Pro jiné SMTP providery (např. Seznam, Outlook):
# Seznam.cz:
# SMTP_HOST=smtp.seznam.cz
# SMTP_PORT=465

# Outlook/Hotmail:
# SMTP_HOST=smtp-mail.outlook.com
# SMTP_PORT=587
